<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="850"
        Width="1300"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Background="#252526"
                CornerRadius="10"
                Padding="15"
                Margin="0 0 0 10">

            <StackPanel>

                <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="Cyan"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Stay Safe Online!"
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,10"/>

                <TextBlock Name="AsciiBanner"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="Cyan"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

        </Border>

        <!-- MAIN TABS -->

        <TabControl Grid.Row="1"
                    Background="#2D2D30"
                    Foreground="White">

            <!-- ===================================================== -->
            <!-- CHATBOT TAB -->
            <!-- ===================================================== -->

            <TabItem Header="Chatbot">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <RichTextBox Name="ChatDisplay"
                                 IsReadOnly="True"
                                 Background="#2D2D30"
                                 Foreground="White"
                                 FontSize="14"
                                 VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">

                        <TextBox Name="UserInput"
                                 Width="850"
                                 Height="40"
                                 FontSize="14"/>

                        <Button Name="SendButton"
                                Content="Send"
                                Width="120"
                                Height="40"
                                Margin="10,0,0,0"
                                Background="Cyan"
                                Click="SendButton_Click"/>

                    </StackPanel>

                </Grid>

            </TabItem>

            <!-- ===================================================== -->
            <!-- TASK ASSISTANT -->
            <!-- ===================================================== -->

            <TabItem Header="Task Assistant">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- INPUT AREA -->

                    <GroupBox Header="Create Cybersecurity Task"
                              Foreground="White"
                              Margin="0,0,0,10">

                        <Grid Margin="10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Title:"
                                       Foreground="White"
                                       Margin="5"/>

                            <TextBox Name="TaskTitleTextBox"
                                     Grid.Column="1"
                                     Margin="5"/>

                            <TextBlock Grid.Row="1"
                                       Text="Description:"
                                       Foreground="White"
                                       Margin="5"/>

                            <TextBox Name="TaskDescriptionTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5"/>

                            <TextBlock Grid.Row="2"
                                       Text="Reminder Date:"
                                       Foreground="White"
                                       Margin="5"/>

                            <DatePicker Name="ReminderDatePicker"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="5"/>

                        </Grid>

                    </GroupBox>

                    <!-- BUTTONS -->

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,10">

                        <Button Name="AddTaskButton"
                                Content="Add Task"
                                Width="120"
                                Margin="5"
                                Click="AddTaskButton_Click"/>

                        <Button Name="RefreshTaskButton"
                                Content="Refresh"
                                Width="120"
                                Margin="5"
                                Click="RefreshTaskButton_Click"/>

                        <Button Name="CompleteTaskButton"
                                Content="Mark Completed"
                                Width="150"
                                Margin="5"
                                Click="CompleteTaskButton_Click"/>

                        <Button Name="DeleteTaskButton"
                                Content="Delete Task"
                                Width="120"
                                Margin="5"
                                Click="DeleteTaskButton_Click"/>

                    </StackPanel>

                    <!-- TASK GRID -->

                    <DataGrid Name="TasksDataGrid"
          Grid.Row="2"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          Background="#1E1E1E"
          Foreground="Black"
          RowBackground="White"
          AlternatingRowBackground="#F2F2F2"
          GridLinesVisibility="All"
          HeadersVisibility="Column">

                        <DataGrid.Resources>

                            <!-- HEADER STYLE -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8"/>
                            </Style>

                            <!-- CELL STYLE -->
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>

                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID"
                            Binding="{Binding TaskId}"
                            Width="70"/>

                            <DataGridTextColumn Header="Title"
                            Binding="{Binding Title}"
                            Width="200"/>

                            <DataGridTextColumn Header="Description"
                            Binding="{Binding Description}"
                            Width="300"/>

                            <DataGridTextColumn Header="Reminder"
                            Binding="{Binding ReminderDate}"
                            Width="180"/>

                            <DataGridTextColumn Header="Created"
                            Binding="{Binding CreatedDate}"
                            Width="180"/>

                            <DataGridTextColumn Header="Status"
                            Binding="{Binding Status}"
                            Width="120"/>

                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>

            </TabItem>

            <!-- ===================================================== -->
            <!-- QUIZ TAB -->
            <!-- ===================================================== -->

            <TabItem Header="Cybersecurity Quiz">

                <ScrollViewer>

                    <StackPanel Margin="20">

                        <TextBlock Text="Cybersecurity Knowledge Quiz"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="Cyan"
                                   Margin="0,0,0,20"/>

                        <TextBlock Name="QuestionTextBlock"
                                   FontSize="18"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"/>

                        <RadioButton Name="OptionA"
                                     FontSize="16"
                                     Foreground="White"
                                     Margin="5"/>

                        <RadioButton Name="OptionB"
                                     FontSize="16"
                                     Foreground="White"
                                     Margin="5"/>

                        <RadioButton Name="OptionC"
                                     FontSize="16"
                                     Foreground="White"
                                     Margin="5"/>

                        <RadioButton Name="OptionD"
                                     FontSize="16"
                                     Foreground="White"
                                     Margin="5"/>

                        <Button Name="SubmitAnswerButton"
                                Content="Submit Answer"
                                Width="180"
                                Height="40"
                                Margin="0,20,0,10"
                                Click="SubmitAnswerButton_Click"/>

                        <Button Name="StartQuizButton"
                                Content="Start Quiz"
                                Width="180"
                                Height="40"
                                Margin="0,0,0,20"
                                Click="StartQuizButton_Click"/>

                        <TextBlock Name="QuizResultTextBlock"
                                   FontSize="16"
                                   Foreground="LightGreen"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </ScrollViewer>

            </TabItem>

            <!-- ===================================================== -->
            <!-- ACTIVITY LOG TAB -->
            <!-- ===================================================== -->

            <TabItem Header="Activity Log">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Name="ActivityListBox"
                             Background="#2D2D30"
                             Foreground="White"/>

                    <Button Grid.Row="1"
                            Name="ShowMoreButton"
                            Content="Show More"
                            Width="150"
                            Height="40"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Click="ShowMoreButton_Click"/>

                </Grid>

            </TabItem>

        </TabControl>

    </Grid>

</Window>